{
  "name": "notebooklm-porter",
  "version": "0.1.0",
  "private": true,
  "description": "Port YouTube playlists and web threads (X, Hacker News, Reddit) into Google NotebookLM as clean, structured sources.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "typecheck": "wxt prepare && tsgo --noEmit",
    "lint": "oxlint",
    "lint:ci": "oxlint --deny-warnings",
    "fmt": "oxfmt --write src",
    "fmt:check": "oxfmt --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "oxfmt --check src && oxlint && wxt prepare && tsgo --noEmit && vitest run && wxt build"
  },
  "dependencies": {
    "effect": "4.0.0-beta.93",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.93",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.3.1",
    "@types/chrome": "^0.1.43",
    "@typescript/native-preview": "^7.0.0-dev.20260618.1",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wxt": "^0.20.26"
  },
  "packageManager": "bun@1.4.0"
}
